# A distinct LN Markets API key restricted to Read permission only.
# Never put the trading key, secret, or passphrase in this file.
LNM_DASHBOARD_KEY=
LNM_DASHBOARD_SECRET=
LNM_DASHBOARD_PASSPHRASE=

# Optional: leave at mainnet unless deliberately running a signet dashboard.
LNM_DASHBOARD_BASE_URL=https://api.lnmarkets.com/v3

# Optional public ticker stream. It never uses credentials or affects trading.
LNM_DASHBOARD_WS_URL=wss://stream.lnmarkets.com/v1
