# LN Markets API credentials.
# Copy this to .env and fill in real values. NEVER commit .env.
#
# Network: one of "testnet" | "mainnet". Drives default base URLs.
LNM_NETWORK=testnet

# Leave URL overrides blank unless LN Markets gives you a replacement endpoint.
# The app selects signet for testnet and production endpoints for mainnet.
LNM_BASE_URL=
LNM_WS_URL=

# API credentials — leave blank to run in "mock" mode (paper/live against a fake exchange).
# Provision from your LN Markets profile > API keys.
LNM_ACCESS_KEY=
LNM_ACCESS_SECRET=
LNM_ACCESS_PASSPHRASE=

# Kill switch. ANY of these being set halts trading.
# TRIGGERING THE KILL SWITCH FROM OUTSIDE THE PROCESS is the intended use.
# Set to 1 to halt; leave blank to allow.
HALTED=
# Presence of this file halts trading; leave blank only if you deliberately
# disable the external kill switch.
HALT_FILE=/var/lib/lnmbot/HALT

# Local persistence
STORAGE_DB_PATH=./lnmarkets.sqlite
STORAGE_LOG_PATH=./logs/lnmarkets-bot.jsonl
STORAGE_LOG_LEVEL=INFO

# Hard risk limits. These are enforced outside the strategy and cannot be bypassed.
RISK_MAX_POSITION_USD=1
RISK_MAX_LEVERAGE=1
RISK_MAX_DAILY_LOSS_USD=1
RISK_MAX_ORDERS_PER_MINUTE=1
# Optional aggregate caps across 1d and 4h. Uncomment to enable.
# RISK_MAX_TOTAL_NOTIONAL_USD=2
# RISK_MAX_TOTAL_MARGIN_USD=2

# Live sizing. `fixed_notional` requests this many USD 1-contracts per TF.
# `equity_fraction` calculates per-TF notional from the account balance at
# entry time, subject to the hard risk limits above.
SIZING_MODE=fixed_notional
SIZING_FIXED_NOTIONAL_USD=1
SIZING_LEVERAGE=1
SIZING_TOTAL_MARGIN_FRACTION=0.50
SIZING_TIMEFRAME_WEIGHTS={"1d": 0.5, "4h": 0.5}
SIZING_EQUITY_HAIRCUT=0.95

# Optional 4h-only CHOP regime overlay. When enabled, a completed 4h bar with
# CHOP(14) > 61.8 requests half the normal entry notional. It does not affect
# exits, leverage, cooldowns, or 1d. Leave disabled unless deliberately adopted.
STRATEGY_4H_CHOP_REDUCE_ENABLED=false
STRATEGY_CHOP_LOOKBACK=14
STRATEGY_CHOP_HIGH_THRESHOLD=61.8
STRATEGY_CHOP_HIGH_SIZE_MULTIPLIER=0.5

# Funding simulation (backtest only; live uses real LNM funding)
BACKTEST_FUNDING_RATE_PER_8H=0.0001

# Backtest data
BACKTEST_DATA_PATH=./data/cache/btcusdt_perp_1m.parquet
